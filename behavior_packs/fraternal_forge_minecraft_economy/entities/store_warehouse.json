{
    "format_version": "1.21.0",
    "minecraft:entity": {
        "description": {
            "identifier": "minecraft-economy:store-warehouse",
            "is_spawnable": false,
            "is_summonable": true,
            "is_experimental": false
        },
        "component_groups": {
            "0": {
                "minecraft:inventory": {
                    "inventory_size": 1,
                    "container_type": "container",
                    "can_be_siphoned_from": true
                }
            },
            "1": {
                "minecraft:inventory": {
                    "inventory_size": 45,
                    "container_type": "container",
                    "can_be_siphoned_from": true
                },
                "minecraft:type_family": {
                    "family": [
                        "metalchest",
                        "inanimate"
                    ]
                }
            },
            "2": {
                "minecraft:inventory": {
                    "inventory_size": 54,
                    "container_type": "container",
                    "can_be_siphoned_from": true
                }
            },
            "3": {
                "minecraft:inventory": {
                    "inventory_size": 81,
                    "container_type": "container",
                    "can_be_siphoned_from": true
                }
            },
            "4": {
                "minecraft:inventory": {
                    "inventory_size": 108,
                    "container_type": "container",
                    "can_be_siphoned_from": true
                }
            },
            "5": {
                "minecraft:inventory": {
                    "inventory_size": 126,
                    "container_type": "container",
                    "can_be_siphoned_from": true
                }
            },
            "open_chest_group": {
                "minecraft:entity_sensor": {
                    "subsensors": [
                        {
                            "range": [3, 3],
                            "event_filters": {
                                "none_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "operator": "!=",
                                        "value": "player"
                                    },
                                    {
                                        "test": "has_container_open",
                                        "operator": "==",
                                        "subject": "other"
                                    }
                                ]
                            },
                            "event": "close_chest_event"
                        }  
                    ]
                }
            },
            "close_chest_group": {
                "minecraft:entity_sensor": {
                    "subsensors": [
                        {
                            "range": [3, 3],
                            "event_filters": {
                                "all_of": [
                                    {
                                        "test": "is_family",
                                        "subject": "other",
                                        "value": "player"
                                    },
                                    {
                                        "test": "has_container_open",
                                        "operator": "==",
                                        "subject": "other"
                                    }
                                ]
                            },
                            "event": "open_chest_event"
                        }
                    ]                    
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [
                    "chest",
                    "inanimate"
                ]
            },
            "minecraft:breathable": {
                "total_supply": 20,
                "suffocate_time": 0,
                "breathes_water": true,
                "breathes_solids": true
            },
            "minecraft:collision_box": {
                "width": 0.8,
                "height": 0.875
            },
            "minecraft:nameable": {
                "allow_name_tag_renaming": false
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "cause": "block_explosion",
                        "deals_damage": "yes"
                    },
                    {
                        "cause": "entity_explosion",
                        "deals_damage": "yes"
                    },
                    {
                        "cause": "all",
                        "deals_damage": "yes"
                    }
                ]
            }
        },
        "events": {
            "open_chest_event": {
                "add": {
                    "component_groups": [
                        "open_chest_group"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "close_chest_group"
                    ]
                },
                "queue_command": {
                  "command": "say Chest Open"
                }
            },
            "close_chest_event": {
                "filters": [
                    {
                        "test": "is_family",
                        "subject": "other",
                        "value": "player"
                    },
                    {
                        "test": "has_container_open",
                        "operator": "==",
                        "subject": "other"
                    }
                ],
                "add": {
                    "component_groups": [
                        "close_chest_group"
                    ]
                },
                "remove": {
                    "component_groups": [
                        "open_chest_group"
                    ]
                }
            },
            "die": {
                "queue_command": {
                    "command": "kill @s"
                }
            },
            "store_warehouse": {
                "add": {
                    "component_groups": [
                        "5",
                        "close_chest_group"
                    ]
                }
            }
        }
    }
}